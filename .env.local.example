# Supabase 設定（このファイルを .env.local にコピーして値を埋める）
# 値は Supabase ダッシュボード → Project Settings → API から取得できます。

# Project URL（例: https://xxxxxxxx.supabase.co）
NEXT_PUBLIC_SUPABASE_URL=

# anon public キー（"anon"/"publishable" と表示される公開キー。秘密鍵ではない）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# seed.sql 実行時に notice に出た店舗の uuid
# （SQL Editor の実行結果メッセージ "Seed 完了: store_id = ..." を貼る）
NEXT_PUBLIC_STORE_ID=

# 注文/会計をサーバー関数(Edge Function/RPC)経由にするか。
# supabase/functions.sql を実行し、submit_order をデプロイした「後」に true にする。
# （デプロイ前は空/false のままで、従来の直接書き込みで動く）
NEXT_PUBLIC_ORDER_VIA_FUNCTION=
